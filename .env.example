# LLM Provider — set AZURE_OPENAI_ENDPOINT to use Azure, leave blank to use OpenAI direct
OPENAI_API_KEY=

# Azure OpenAI (fill these if using Azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure deployment names (must match what you created in Azure OpenAI Studio)
AZURE_DEPLOYMENT_GPT4O=gpt-4o
AZURE_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini
AZURE_DEPLOYMENT_EMBEDDING=text-embedding-3-small

# Redis
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
